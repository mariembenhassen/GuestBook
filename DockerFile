# Use official PHP 8.5 Apache image
FROM php:8.5-apache

# Set working directory
WORKDIR /var/www/html

# Install system dependencies + build tools
RUN apt-get update && apt-get install -y \
        libsqlite3-dev \
        pkg-config \
        libzip-dev \
        unzip \
        libxml2-dev \
        libxslt1-dev \
        git \
        librabbitmq-dev \
        libssl-dev \
        libssh-dev \
        zlib1g-dev \
    && docker-php-ext-install -j$(nproc) \
        pdo_sqlite \
        xsl \
        zip \
    && pecl install amqp \
    && docker-php-ext-enable amqp \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# Enable Apache modules needed for Symfony
RUN a2enmod rewrite

# Copy project files
COPY . .

# Configure Git safe directory (useful inside container)
RUN git config --global --add safe.directory /var/www/html

# Install Composer
COPY --from=composer:2 /usr/bin/composer /usr/bin/composer

# Install Composer dependencies (no dev packages for production-like build)
RUN COMPOSER_ALLOW_SUPERUSER=1 composer install --no-dev --optimize-autoloader --no-interaction --no-scripts

# Clear Symfony cache in production
RUN php bin/console cache:clear --env=prod --no-warmup || true

# ==================== CRITICAL PART FOR RENDER ====================
# Tell Apache the correct document root is /public
ENV APACHE_DOCUMENT_ROOT /var/www/html/public
RUN sed -ri -e 's!/var/www/html!${APACHE_DOCUMENT_ROOT}!g' /etc/apache2/sites-available/*.conf
RUN sed -ri -e 's!/var/www/!${APACHE_DOCUMENT_ROOT}!g' /etc/apache2/apache2.conf /etc/apache2/conf-available/*.conf

# Allow .htaccess overrides in the public folder
RUN sed -ri -e 's/AllowOverride None/AllowOverride All/g' /etc/apache2/apache2.conf

# Expose port
EXPOSE 80

# Start Apache
CMD ["apache2-foreground"]